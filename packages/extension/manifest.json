{
  "manifest_version": 3,
  "key": "",
  "name": "Vortex",
  "description": "Let your AI agent drive your real, logged-in Chrome — browser automation for LLMs via MCP.",
  "version": "0.5.0",
  "permissions": [
    "nativeMessaging",
    "debugger",
    "scripting",
    "tabs",
    "webNavigation",
    "downloads",
    "cookies",
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Vortex",
    "default_popup": "src/popup.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-main.ts"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-isolated.ts"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
