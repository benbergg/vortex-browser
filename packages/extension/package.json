{
  "name": "@bytenew/vortex-extension",
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "build": "vite build && node scripts/build-page-side.mjs",
    "build:main": "vite build",
    "build:page-side": "node scripts/build-page-side.mjs",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "depcruise:check": "depcruise --config .dependency-cruiser.cjs --output-type err src",
    "depcruise:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot src | dot -T svg > dep-graph.svg"
  },
  "dependencies": {
    "@bytenew/vortex-shared": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "dependency-cruiser": "^17.3.10",
    "jsdom": "^29.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
