node_modules/
dist/
.env
.env.local

# reports：仅 baseline.json、archived baselines 和 boxes-budget-*.json
# （PR 证据 / 历史 baseline 审计轨迹）入库；transient latest.json 不入。
reports/*.json
!reports/baseline.json
!reports/boxes-budget-*.json
!reports/archive/
reports/*.md
!reports/README.md

# scan 运行产物(transient discovery 报告,按时间戳生成,不入库)
reports/scan/

# robustness 运行产物(同 scan,transient discovery 报告,不入库)
reports/robustness/

# robustness-live 运行产物(同 scan/robustness,transient,不入库)
reports/robustness-live/

# judge 运行产物(同 scan/robustness,transient,不入库)
reports/judge/
