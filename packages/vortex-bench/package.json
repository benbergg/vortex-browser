{
  "name": "@bytenew/vortex-bench",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "bin": {
    "vortex-bench": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "playground": "vite --config playground/vite.config.ts",
    "playground:build": "vite build --config playground/vite.config.ts",
    "bench": "tsx src/index.ts",
    "bench:baseline": "tsx src/index.ts run --all && cp reports/latest.json reports/baseline.json && echo '[bench] baseline.json refreshed from latest.json'",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bytenew/vortex-shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "element-plus": "^2.8.0",
    "openai": "^6.39.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  }
}
